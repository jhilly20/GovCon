# Government Opportunity Scrapers - Environment Variables
# Copy this file to .env and fill in your credentials

# Monday.com
MONDAY_API_KEY=your_monday_api_key_here
MONDAY_BOARD_ID=your_board_id_here

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL=your_slack_channel_id_here

# Scraper-specific Slack channels (optional, for per-scraper DM/channel targets)
# BROOKE_SLACK_CHANNEL=your_brooke_channel_or_dm_id_here
# CUAS_SLACK_CHANNEL=your_cuas_channel_id_here

# SAM.gov (required for SAM.gov scrapers)
# SAM_API_KEY=your_sam_api_key_here
